<ProxyEndpoint name="default">
  <Description>Claude Code Gateway - Proxy Endpoint</Description>

  <FaultRules>
    <FaultRule name="quota-violation">
      <Condition>fault.name = "QuotaViolation"</Condition>
      <Step>
        <Name>AM-QuotaError</Name>
      </Step>
    </FaultRule>
  </FaultRules>

  <HTTPProxyConnection>
    <BasePath>/v1</BasePath>
  </HTTPProxyConnection>

  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>VA-VerifyAPIKey</Name>
      </Step>
      <Step>
        <Name>AM-SetModelVar</Name>
        <Condition>(proxy.pathsuffix MatchesPath "/messages") and (request.verb = "POST")</Condition>
      </Step>
      <Step>
        <Name>LTQ-TokenEnforce</Name>
        <Condition>(proxy.pathsuffix MatchesPath "/messages") and (request.verb = "POST")</Condition>
      </Step>
      <Step>
        <Name>AM-StripClientAuth</Name>
      </Step>
      <!-- JS-ExtractModelAndBuildTargetUrl runs in TargetEndpoint PreFlow -->
    </Request>
    <Response>
      <Step>
        <Name>AM-AddQuotaHeaders</Name>
      </Step>
    </Response>
  </PreFlow>

  <Flows>
    <Flow name="messages">
      <Condition>(proxy.pathsuffix MatchesPath "/messages") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="count-tokens">
      <Condition>(proxy.pathsuffix MatchesPath "/messages/count_tokens") and (request.verb = "POST")</Condition>
    </Flow>
    <Flow name="models-list">
      <Description>Return static model list (no Vertex AI equivalent)</Description>
      <Condition>(proxy.pathsuffix MatchesPath "/models") and (request.verb = "GET")</Condition>
      <Response>
        <Step>
          <Name>AM-StaticModelList</Name>
        </Step>
      </Response>
    </Flow>
  </Flows>

  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>

  <RouteRule name="models-no-backend">
    <Condition>(proxy.pathsuffix MatchesPath "/models") and (request.verb = "GET")</Condition>
  </RouteRule>
  <RouteRule name="streaming">
    <Condition>claude.is_streaming = "true"</Condition>
    <TargetEndpoint>target-streaming</TargetEndpoint>
  </RouteRule>
  <RouteRule name="non-streaming">
    <TargetEndpoint>target-nonstreaming</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
