<TargetEndpoint name="target-nonstreaming">
  <Description>Vertex AI Claude Backend - non-streaming responses with PostFlow token counting</Description>

  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>JS-ExtractModelAndBuildTargetUrl</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>

  <Flows/>

  <PostFlow name="PostFlow">
    <Request/>
    <Response>
      <Step>
        <Name>JS-ExtractNonStreamTokens</Name>
      </Step>
      <Step>
        <Name>LTQ-TokenCountNonStream</Name>
        <Condition>non_stream.output_tokens != null</Condition>
      </Step>
    </Response>
  </PostFlow>

  <HTTPTargetConnection>
    <URL>https://aiplatform.googleapis.com</URL>
    <Properties>
      <Property name="io.timeout.millis">300000</Property>
    </Properties>
    <Authentication>
      <GoogleAccessToken>
        <Scopes>
          <Scope>https://www.googleapis.com/auth/cloud-platform</Scope>
        </Scopes>
      </GoogleAccessToken>
    </Authentication>
  </HTTPTargetConnection>
</TargetEndpoint>
